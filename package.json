{
  "name": "copilot-runway",
  "version": "0.0.0",
  "description": "A local web dashboard for visualizing and orchestrating multiple GitHub Copilot CLI sessions across multiple projects",
  "main": "server.js",
  "bin": {
    "copilot-runway": "bin/copilot-runway.js"
  },
  "files": [
    "bin/",
    "lib/",
    "public/",
    "server.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "github",
    "copilot",
    "cli",
    "dashboard",
    "session-manager"
  ],
  "author": "James Croft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesmcroft/copilot-runway.git"
  },
  "homepage": "https://github.com/jamesmcroft/copilot-runway",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.4"
  }
}
